# Copy to .env and fill in as needed. All values below are optional —
# splunk/config.py defaults are shown; uncomment/edit only what you need
# to override. See splunk/config.py for the authoritative source.

# ---------------------------------------------------------------------------
# Splunk connection (required for --live / splunk.auth)
# ---------------------------------------------------------------------------

# Splunk base URL — required for live queries and auth.
SPLUNK_URL=

# Splunk index used by default queries.
SPLUNK_INDEX=pki

# Session cookie name set by your Splunk deployment's SSO.
SPLUNK_COOKIE_NAME=splunkd_8089

# Where the SSO session cookie is persisted after `python -m splunk.auth`.
SPLUNK_AUTH_PATH=~/.splunk/auth.json

# ---------------------------------------------------------------------------
# Job polling (live REST queries)
# ---------------------------------------------------------------------------

SPLUNK_POLL_INTERVAL=2
SPLUNK_POLL_TIMEOUT=300
SPLUNK_MAX_REAUTH=3

# ---------------------------------------------------------------------------
# Investigator loop (splunk/mcp_server.py — Copilot/Claude-driven)
# ---------------------------------------------------------------------------

SPLUNK_INVESTIGATOR_MAX_ITER=3

# ---------------------------------------------------------------------------
# Standalone LangGraph/Ollama agent (splunk/agent.py, --investigate flag).
# Optional fallback for environments without Copilot/Claude Code.
# Requires `uv sync --extra llm` and a running Ollama instance.
# ---------------------------------------------------------------------------

SPLUNK_LLM_MODEL=qwen2.5:14b
SPLUNK_AGENT_MAX_ITER=10

# ---------------------------------------------------------------------------
# Detector thresholds
# ---------------------------------------------------------------------------

# Spike detection: events/window to trigger a spike finding.
SPLUNK_SPIKE_THRESHOLD=10
SPLUNK_SPIKE_WINDOW=60

# Event correlation window (seconds).
SPLUNK_CORRELATE_WINDOW=60

# Duration (ms) above which an event is flagged as a slow query.
SPLUNK_SLOW_QUERY_THRESHOLD_MS=1000

# Rolling z-score anomaly detection: window size (events) and |z| threshold.
SPLUNK_ANOMALY_WINDOW=20
SPLUNK_ANOMALY_Z_THRESHOLD=3.0

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Every run is disposable — logs freely at DEBUG by default.
LOG_LEVEL=DEBUG
